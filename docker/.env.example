# ═══════════════════════════════════════════════════════
# Gino Docker Configuration
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════

# ═══ LLM Provider ════════════════════════════════════

# REQUIRED — API key for your LLM provider
OPENAI_API_KEY=

# OpenAI-compatible API base URL.  Default: https://openrouter.ai/api/v1
# Examples:
#   OpenAI:       https://api.openai.com/v1
#   OpenRouter:   https://openrouter.ai/api/v1
#   Groq:         https://api.groq.com/openai/v1
#   z.ai coding:  https://api.z.ai/api/coding/paas/v4
#   Ollama local: http://localhost:11434/v1
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Model identifier (provider-specific).  No default — must be set.
GINO_MODEL=google/gemini-2.5-flash

# Max response tokens per message.  Default: 8192
GINO_MAX_TOKENS=8192

# Max tool call iterations per message.  Default: 100
GINO_MAX_TOOL_ITERATIONS=100

# ═══ Telegram ════════════════════════════════════════

# Bot token from @BotFather.  Optional — leave empty to disable Telegram.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to chat.  Optional but recommended.
TELEGRAM_ALLOW_FROM=

# ═══ Discord ═════════════════════════════════════════

# Bot token from Discord Developer Portal.  Optional — leave empty to disable Discord.
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to chat.  Optional but recommended.
DISCORD_ALLOW_FROM=

# ═══ Knowledge Brain ═════════════════════════════════
# Hybrid search (FTS5 + vector) and knowledge graph.
# Uses bundled Ollama by default, or set OLLAMA_URL for external.

# Enable the knowledge brain.  Default: true
# When true and no OLLAMA_URL is set, starts bundled Ollama automatically.
GINO_BRAIN_ENABLED=true

# Ollama embedding model (auto-pulled on first start).  Default: nomic-embed-text
GINO_BRAIN_EMBEDDING_MODEL=nomic-embed-text

# External Ollama URL.  Default: empty (use bundled Ollama).
# Set this to skip starting the in-container Ollama and use an external instance.
# Examples: http://host.docker.internal:11434  or  http://192.168.1.100:11434
OLLAMA_URL=

# ═══ Remote Embedding API ════════════════════════════
# Alternative to Ollama — works with any OpenAI-compatible embedding endpoint.
# If set, used as fallback when Ollama is unavailable.
# All optional — default: empty (disabled).

GINO_BRAIN_REMOTE_API_BASE=
GINO_BRAIN_REMOTE_API_KEY=
GINO_BRAIN_REMOTE_MODEL=

# ═══ Docker Settings ═════════════════════════════════

# Absolute host path to persist Gino data (config, workspace, brain DB).
# Default: /opt/gino/data
GINO_DATA_PATH=/opt/gino/data
