# Gino Docker Configuration
# Copy to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ═══ LLM Provider ════════════════════════════════════

# REQUIRED: API key for your LLM provider
OPENAI_API_KEY=

# API base URL (any OpenAI-compatible endpoint)
# OpenAI:      https://api.openai.com/v1
# OpenRouter:  https://openrouter.ai/api/v1
# Ollama:      http://localhost:11434/v1
# Groq:        https://api.groq.com/openai/v1
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Model identifier (provider-specific)
GINO_MODEL=google/gemini-2.5-flash

# Max response tokens per message
GINO_MAX_TOKENS=8192

# Max tool call iterations per message
GINO_MAX_TOOL_ITERATIONS=100

# ═══ Telegram ════════════════════════════════════════

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to chat
TELEGRAM_ALLOW_FROM=

# ═══ Discord ═════════════════════════════════════════

# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to chat
DISCORD_ALLOW_FROM=

# ═══ Slack ═══════════════════════════════════════════

# App-level token (xapp-...)
SLACK_APP_TOKEN=

# Bot token (xoxb-...)
SLACK_BOT_TOKEN=

# Comma-separated Slack user IDs allowed to chat
SLACK_ALLOW_USERS=

# Comma-separated Slack channel IDs allowed to chat
SLACK_ALLOW_CHANNELS=

# ═══ Knowledge Brain ═════════════════════════════════
# Hybrid search (FTS5 + vector) and knowledge graph.
# Uses bundled Ollama by default, or set OLLAMA_URL for external.

# Enable the knowledge brain (also starts bundled Ollama)
GINO_BRAIN_ENABLED=false

# Ollama embedding model (auto-pulled on first start)
GINO_BRAIN_EMBEDDING_MODEL=nomic-embed-text

# External Ollama URL (leave empty to use bundled Ollama)
# Examples: http://host.docker.internal:11434 or http://192.168.1.100:11434
OLLAMA_URL=

# ═══ Remote Embedding API ════════════════════════════
# Alternative to Ollama. Works with any OpenAI-compatible endpoint.
# If set, used as fallback when Ollama is unavailable.
GINO_BRAIN_REMOTE_API_BASE=
GINO_BRAIN_REMOTE_API_KEY=
GINO_BRAIN_REMOTE_MODEL=

# ═══ Docker Settings ═════════════════════════════════

# Path on the host to persist Gino data (config, workspace, brain DB)
GINO_DATA_PATH=./gino-data
